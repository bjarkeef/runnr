# Required: Strava OAuth
STRAVA_CLIENT_ID=your_strava_client_id
STRAVA_CLIENT_SECRET=your_strava_client_secret
STRAVA_REDIRECT_URI=http://localhost:3000/api/auth/callback

# Required: Prisma + PostgreSQL
# DATABASE_URL: app/runtime connection (pooled URL for many cloud providers)
# DIRECT_URL: direct connection used by Prisma migrations
# If you only have one local PostgreSQL URL, set both to the same value.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/runnr
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/runnr

# Optional: route planning API (required only for route generation feature)
OPENROUTESERVICE_API_KEY=your_openrouteservice_api_key

# Optional: default map center for route planner (Odense, DK)
NEXT_PUBLIC_ROUTE_PLANNER_LAT=55.4038
NEXT_PUBLIC_ROUTE_PLANNER_LNG=10.4024
